# Agent Telegram Bridge configuration
# Copy to .env and fill values. Never commit .env or state files.
#
# Run one bridge instance per agent provider. Each provider instance needs its
# own TELEGRAM_BOT_TOKEN, STATE_DIR, and supervisor instance (systemd or launchd) so their
# pollers, locks, and runtime state never overlap.

TELEGRAM_BOT_TOKEN=your-bot-token

# Which coding agent to bridge over ACP stdio: grok | copilot
AGENT_PROVIDER=grok

# Absolute path to the working directory for the agent session.
# Keep the bridge installation, .env files, credentials, and unrelated repositories outside this directory.
AGENT_CWD=/absolute/path/to/your/project

# Optional comma-separated allowlist of CWDs for /cwd switching (primary AGENT_CWD is always included)
# AGENT_CWD_ALLOWLIST=/absolute/path/to/your/project,/absolute/path/to/another/project

# Path to the agent binary.
#   grok    -> defaults to grok in PATH or common locations
#   copilot -> defaults to /usr/bin/copilot on Linux and copilot in PATH on macOS
# AGENT_BIN=grok

# Model to use with the grok agent. Copilot never receives a --model argument.
AGENT_MODEL=grok-4.5

# Optional display name used in Telegram help, permission cards, and errors.
# Defaults: grok -> "Grok Build", copilot -> "GitHub Copilot CLI".
# AGENT_DISPLAY_NAME=

# Directory for access.json, lock.json, health.json (will be created with 0700)
STATE_DIR=./.agent-telegram-state

# Set to "true" to auto-approve all ACP permissions (insecure; default false).
#   grok    -> prefers the session-scoped allow_always option when ACP offers it.
#   copilot -> launches with --allow-all. Leave false to forward permissions to Telegram.
AGENT_ALWAYS_APPROVE=false

# Legacy Grok aliases (still accepted for migration; AGENT_* names take precedence):
#   GROK_CWD, GROK_BIN, GROK_MODEL, GROK_ALWAYS_APPROVE, GROK_CWD_ALLOWLIST

# Start with thought-stream verbose mode enabled (default false; toggle via /verbose)
# VERBOSE_DEFAULT=false

# Media ingress limits
# MEDIA_MAX_BYTES=20971520
# MEDIA_MIME_ALLOWLIST=image/png,image/jpeg,image/gif,image/webp,image/bmp,audio/mpeg,audio/ogg,audio/wav,video/mp4,video/webm,application/pdf,text/plain,text/markdown,application/json,application/zip

# Prompt queue depth while ACP is busy (0 = reject follow-ups)
# PROMPT_QUEUE_MAX=3

# How long to wait for ACP to idle after /cancel (ms, maximum 30000)
# CANCEL_WAIT_MS=15000

# How long /retry last keeps the last final response (ms)
# RETRY_LAST_TTL_MS=1800000

# Optional runtime overrides
# PAIRING_EXPIRY_MS=300000
# PAIRING_PENDING_MAX=100
# PERMISSION_TIMEOUT_MS=300000
# PROMPT_STALE_AFTER_MS=900000
# MAX_TYPING_SESSION_MS=1800000
# STREAM_EDIT_INTERVAL_MS=1500
# STREAM_MIN_DELTA_CHARS=24
# STREAM_DRAFT_MAX=3800
# PROGRESS_NOTICE_AFTER_MS=90000
# PROGRESS_NOTICE_INTERVAL_MS=120000
# PROGRESS_NOTICE_ITERATION_MS=60000
# PROGRESS_NOTICE_MAX_ITERATIONS=90
# SEND_PACE_MS=50
# TELEGRAM_OUTBOUND_QUEUE_MAX=100
# Maximum 5 retries.
# TELEGRAM_RETRY_MAX=5
# ASSISTANT_TEXT_MAX_CHARS=200000
# TYPING_INTERVAL_MS=4000
# TYPING_DEBOUNCE_MS=60000
# HEALTH_WRITE_MIN_INTERVAL_MS=5000
# Maximum 30000 ms.
# API_TIMEOUT_MS=30000
# PERMISSION_SUMMARY_MAX=1800
# WATCHDOG_INTERVAL_MS=30000
# BUBBLE_DEBOUNCE_MS=300
# THOUGHT_EDIT_INTERVAL_MS=2500
