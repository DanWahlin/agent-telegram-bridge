{
  "name": "agent-telegram-bridge",
  "version": "0.1.0",
  "description": "Secure Telegram bridge for coding agents (Grok Build and GitHub Copilot CLI) using the official Agent Client Protocol (ACP)",
  "private": true,
  "type": "module",
  "license": "MIT",
  "main": "dist/src/index.js",
  "bin": {
    "agent-telegram-bridge": "dist/src/index.js"
  },
  "scripts": {
    "prebuild": "npm run clean",
    "build": "tsc -p tsconfig.json && chmod +x dist/src/index.js && npm run build:native",
    "build:native": "tsx scripts/build-native-addon.ts",
    "render:launchd": "node dist/scripts/render-launchd.js",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.test.json",
    "lint": "eslint \"src/**/*.ts\" \"scripts/**/*.ts\"",
    "pretest": "npm run build:native",
    "test": "vitest run",
    "test:watch": "vitest",
    "presmoke": "npm run build:native",
    "smoke": "tsx scripts/smoke-acp.ts",
    "start": "node dist/src/index.js",
    "prestart:dev": "npm run build:native",
    "start:dev": "tsx src/index.ts",
    "clean": "tsx scripts/clean.ts"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^1.2.1",
    "dotenv": "^17.4.2",
    "grammy": "^1.45.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.13.3",
    "eslint": "^10.7.0",
    "node-gyp": "^12.4.0",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "os": [
    "linux",
    "darwin"
  ],
  "files": [
    "dist",
    "deploy",
    "native",
    "scripts/build-native-addon.ts",
    "scripts/launch-agent.ts",
    "scripts/render-launchd.ts",
    "images/logo.webp",
    ".env.example",
    "AGENTS.md",
    "README.md",
    "SECURITY.md",
    "LICENSE"
  ]
}
