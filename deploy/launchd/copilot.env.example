# Install as ~/.config/agent-telegram/copilot.env with mode 0600.
# Replace every placeholder. This is dotenv syntax, not a shell script.
TELEGRAM_BOT_TOKEN=[REDACTED]
AGENT_PROVIDER=copilot
AGENT_CWD=/Users/YOUR_USER/projects/YOUR_PROJECT
AGENT_CWD_ALLOWLIST=/Users/YOUR_USER/projects/YOUR_PROJECT
AGENT_BIN=/opt/homebrew/bin/copilot
AGENT_DISPLAY_NAME=GitHub Copilot CLI
AGENT_ALWAYS_APPROVE=false
STATE_DIR="/Users/YOUR_USER/Library/Application Support/AgentTelegram/copilot"
