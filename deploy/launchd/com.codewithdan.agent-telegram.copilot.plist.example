<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.codewithdan.agent-telegram.copilot</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/sh</string>
    <string>__REPO_DIR__/deploy/launchd/run-agent-telegram.sh</string>
  </array>

  <key>EnvironmentVariables</key>
  <dict>
    <key>AGENT_TELEGRAM_ENV_FILE</key>
    <string>__HOME__/.config/agent-telegram/copilot.env</string>
  </dict>

  <key>WorkingDirectory</key>
  <string>__REPO_DIR__</string>

  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>ThrottleInterval</key>
  <integer>10</integer>
  <key>ProcessType</key>
  <string>Background</string>
  <key>Umask</key>
  <integer>63</integer>

  <key>StandardOutPath</key>
  <string>__HOME__/Library/Logs/agent-telegram-copilot.log</string>
  <key>StandardErrorPath</key>
  <string>__HOME__/Library/Logs/agent-telegram-copilot.error.log</string>
</dict>
</plist>
