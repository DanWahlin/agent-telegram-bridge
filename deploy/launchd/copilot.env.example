# Install as ~/.config/agent-telegram/copilot.env with mode 0600.
# Replace every placeholder. Never commit a real token.
TELEGRAM_BOT_TOKEN=[REDACTED]
AGENT_PROVIDER=copilot
AGENT_CWD=/Users/YOUR_USER/projects/YOUR_PROJECT
AGENT_CWD_ALLOWLIST=/Users/YOUR_USER/projects/YOUR_PROJECT
AGENT_BIN=/opt/homebrew/bin/copilot
AGENT_DISPLAY_NAME=GitHub Copilot CLI
AGENT_ALWAYS_APPROVE=false
STATE_DIR="$HOME/Library/Application Support/AgentTelegram/copilot"

# Apple Silicon Homebrew defaults are shown. Intel Homebrew commonly uses /usr/local/bin.
PATH=/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin
NODE_BIN=/opt/homebrew/bin/node
AGENT_TELEGRAM_REPO=/Users/YOUR_USER/projects/agent-telegram-bridge
