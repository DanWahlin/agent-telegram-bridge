<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.codewithdan.agent-telegram.copilot</string>

  <key>ProgramArguments</key>
  <array>
    <string>__NODE_BIN__</string>
    <string>__REPO_DIR__/dist/scripts/launch-agent.js</string>
    <string>__ENV_FILE__</string>
  </array>

  <key>WorkingDirectory</key>
  <string>__REPO_DIR__</string>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>ThrottleInterval</key>
  <integer>10</integer>
  <key>ProcessType</key>
  <string>Background</string>
  <key>AbandonProcessGroup</key>
  <false/>
  <key>ExitTimeOut</key>
  <integer>20</integer>
  <key>Umask</key>
  <integer>63</integer>

  <key>StandardOutPath</key>
  <string>__HOME__/Library/Logs/agent-telegram-copilot.log</string>
  <key>StandardErrorPath</key>
  <string>__HOME__/Library/Logs/agent-telegram-copilot.error.log</string>
</dict>
</plist>
