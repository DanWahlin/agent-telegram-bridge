# Install as /etc/agent-telegram/copilot.env with mode 0600.
# Replace the placeholder token. Never commit a real token.
TELEGRAM_BOT_TOKEN=[REDACTED]
AGENT_PROVIDER=copilot
AGENT_BIN=/usr/bin/copilot
AGENT_CWD=/root/projects/ZenSquirrel
AGENT_CWD_ALLOWLIST=/root/projects/ZenSquirrel
AGENT_DISPLAY_NAME="GitHub Copilot CLI"
AGENT_ALWAYS_APPROVE=false
STATE_DIR=/var/lib/agent-telegram/copilot
VERBOSE_DEFAULT=false
